# Grid Trading Bot Configuration
# Copy this file to .env and fill in your actual values

# Exchange Configuration
EXCHANGE_ID=binance
MARKET_TYPE=spot
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Symbol Configuration
SYMBOL=BTC/USDT

# Grid Parameters (see config/grid_config.yaml for full settings)
# TOTAL_CAPITAL=1000.0
# NUM_GRIDS_UP=10
# NUM_GRIDS_DOWN=10
# ORDER_SIZE_QUOTE=50.0

# Telegram Alerting (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange Options
TESTNET=false
