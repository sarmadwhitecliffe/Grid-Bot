{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/adaptive_risk_tiers.schema.json",
  "title": "AdaptiveRiskTiers",
  "type": "object",
  "additionalProperties": false,
  "required": ["description", "version", "tiers", "settings"],
  "properties": {
    "description": { "type": "string" },
    "version": { "type": "string" },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Tier" }
    },
    "settings": { "$ref": "#/$defs/Settings" }
  },
  "$defs": {
    "NullableNumber": { "type": ["number", "null"] },
    "NullableInteger": { "type": ["integer", "null"] },
    "Percent0to100": { "type": "number", "minimum": 0, "maximum": 100 },
    "Ratio0to1Nullable": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "TierName": { "type": "string", "pattern": "^[A-Z_]+$" },
    "Tier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", "description", "min_trades", "max_trades", "min_profit_factor", "max_profit_factor",
        "min_sharpe_ratio", "min_win_rate", "max_drawdown", "max_consecutive_losses",
        "capital_allocation_pct", "max_leverage", "max_position_size_usd"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/TierName" },
        "description": { "type": "string" },
        "min_trades": { "type": "integer", "minimum": 0 },
        "max_trades": { "$ref": "#/$defs/NullableInteger", "minimum": 0 },
        "min_profit_factor": { "type": "number", "minimum": 0 },
        "max_profit_factor": { "$ref": "#/$defs/NullableNumber", "minimum": 0 },
        "min_sharpe_ratio": { "type": ["number", "null"] },
        "min_win_rate": { "$ref": "#/$defs/Ratio0to1Nullable" },
        "max_drawdown": { "$ref": "#/$defs/Ratio0to1Nullable" },
        "max_consecutive_losses": { "$ref": "#/$defs/NullableInteger", "minimum": 0 },
        "capital_allocation_pct": { "$ref": "#/$defs/Percent0to100" },
        "max_leverage": { "type": "integer", "minimum": 1 },
        "max_position_size_usd": { "type": "number", "minimum": 0 }
      }
    },
    "Settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enable_kill_switch", "kill_switch_consecutive_losses", "kill_switch_drawdown_pct",
        "enable_drawdown_scaling", "drawdown_scale_threshold_pct", "drawdown_scale_factor",
        "enable_portfolio_heat_limit", "max_portfolio_heat_pct", "lookback_trades"
      ],
      "properties": {
        "enable_kill_switch": { "type": "boolean" },
        "kill_switch_consecutive_losses": { "type": "integer", "minimum": 1 },
        "kill_switch_drawdown_pct": { "$ref": "#/$defs/Percent0to100" },
        "enable_drawdown_scaling": { "type": "boolean" },
        "drawdown_scale_threshold_pct": { "$ref": "#/$defs/Percent0to100" },
        "drawdown_scale_factor": { "type": "number", "minimum": 0, "maximum": 1 },
        "enable_portfolio_heat_limit": { "type": "boolean" },
        "max_portfolio_heat_pct": { "$ref": "#/$defs/Percent0to100" },
        "lookback_trades": { "type": "integer", "minimum": 1 },
        "pf_min_trades_for_validation": { "type": "integer", "minimum": 0 },
        "boundary_policy": { "type": "string", "enum": ["min_inclusive_max_exclusive", "both_inclusive"] },
        "tier_eval_order": { "type": "array", "items": { "$ref": "#/$defs/TierName" }, "uniqueItems": true },
        "tier_portfolio_caps": {
          "type": "object",
          "description": "Optional per-tier portfolio-wide caps in percent of total capital (e.g., {\"CHAMPION\": 40}).",
          "additionalProperties": { "$ref": "#/$defs/Percent0to100" }
        },
        "drawdown_scaling_overrides": {
          "type": "object",
          "description": "Optional per-tier overrides: { TIER: { threshold_pct, factor } }",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "threshold_pct": { "$ref": "#/$defs/Percent0to100" },
              "factor": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "promotion_rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "promote_after_trades": { "type": "integer", "minimum": 0 },
            "promote_buffer_pf": { "type": "number", "minimum": 0 },
            "min_stay_trades": { "type": "integer", "minimum": 0 }
          }
        },
        "demotion_rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "demote_after_losses": { "type": "integer", "minimum": 0 },
            "demote_buffer_pf": { "type": "number", "minimum": 0 }
          }
        },
        "volatility_sizing_caps": {
          "type": "object",
          "description": "Optional per-volatility-bucket caps (USD). Example keys: low, medium, high.",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "last_review_date": { "type": "string", "format": "date" },
            "auto_adjust_enabled": { "type": "boolean" },
            "data_source": { "type": "string" }
          }
        },
        "comments": {
          "type": "object",
          "description": "Free-form documentation block.",
          "additionalProperties": true
        }
      }
    }
  }
}
